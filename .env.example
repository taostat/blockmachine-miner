# BlockMachine Miner Configuration
# Copy to .env and fill in values: cp .env.example .env

# Authentication secret (generated by install script)
SECRET_V1=
# Secondary secret for zero-downtime rotation (leave empty normally)
SECRET_V2=

# Domain name (used by certbot for auto-renewing TLS)
# Leave empty for self-signed certificates
DOMAIN=

# Subtensor node RPC port
BACKEND_PORT=9944

# TLS certificate paths inside the container
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
